// ===== FILE: prisma/schema.prisma =====
// Database: MySQL | ORM: Prisma
// USDT Watch-Only Payment System

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ══════════════════════════════════════
// ORDERS
// ══════════════════════════════════════

model Order {
  id            String    @id @default(cuid())
  orderNo       String    @unique
  userId        String?
  sessionId     String?
  productId     String?
  productName   String?
  fiatAmount    Int       @default(0) // VND amount
  usdtAmount    Float     @default(0) // Base USDT amount (before marker)
  orderStatus   String    @default("pending") // pending | approved | completed | cancelled | refunded
  paymentStatus String    @default("unpaid") // unpaid | paying | paid | partial | expired | manual_review
  expiresAt     DateTime?
  approvedAt    DateTime?
  approvedBy    String? // system:usdt_watcher | admin:{id}
  completedAt   DateTime?
  metadata      String?   @db.Text // JSON: extra order data
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  paymentAttempts PaymentAttempt[]
  statusLogs      OrderStatusLog[]

  @@index([userId])
  @@index([orderStatus])
  @@index([paymentStatus])
  @@index([createdAt])
}

// ══════════════════════════════════════
// PAYMENT ATTEMPTS
// ══════════════════════════════════════

model PaymentAttempt {
  id               String @id @default(cuid())
  orderId          String
  paymentNo        String @unique
  network          String // TRC20 | BEP20
  tokenSymbol      String @default("USDT")
  tokenContract    String
  receivingAddress String

  // ── Unique Amount Marker ──
  // base_amount = original USDT amount from order
  // unique_amount_marker = small decimal offset (0.001–0.999) unique among active attempts on same network
  // expected_amount = base_amount + unique_amount_marker (what we tell user to send)
  baseAmount         Float // Original USDT amount
  uniqueAmountMarker Float @default(0) // Decimal marker for uniqueness
  expectedAmount     Float // baseAmount + marker = what user sends

  actualReceivedAmount Float? // What blockchain says was received
  amountDelta          Float? // actualReceived - expectedAmount

  qrImageUrl String?
  qrText     String?

  status String @default("pending")
  // Status values:
  //   pending      — waiting for payment
  //   detected     — tx seen on chain, not enough confirmations
  //   confirming   — tx has some confirmations, not enough yet
  //   paid         — fully confirmed and credited
  //   partial      — received less than expected
  //   overpaid     — received more than expected (still auto-approved)
  //   expired      — payment window closed, no valid tx
  //   failed       — system error
  //   late_payment — tx arrived after expiry
  //   manual_review — ambiguous case, needs admin

  txHash                String?
  blockNumber           Int?
  logIndex              Int?
  confirmationCount     Int     @default(0)
  requiredConfirmations Int     @default(20)
  senderAddress         String?

  detectedAt  DateTime?
  confirmedAt DateTime?
  expiresAt   DateTime

  rawMatchPayload String? @db.Text // JSON: full match data for audit

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order          Order              @relation(fields: [orderId], references: [id])
  statusLogs     PaymentStatusLog[]
  transferEvents TransferEvent[]

  @@index([orderId])
  @@index([network, status])
  @@index([network, expectedAmount, status])
  @@index([status, expiresAt])
  @@index([txHash])
  @@index([createdAt])
}

// ══════════════════════════════════════
// BLOCKCHAIN TRANSFER EVENTS
// Idempotent: unique(network, txHash, logIndex)
// Each on-chain transfer recorded exactly once
// ══════════════════════════════════════

model TransferEvent {
  id             String    @id @default(cuid())
  network        String // TRC20 | BEP20
  txHash         String
  logIndex       Int       @default(0)
  fromAddress    String
  toAddress      String
  amount         Float // USDT amount (human-readable)
  tokenContract  String
  blockNumber    Int
  blockTimestamp DateTime?
  confirmations  Int       @default(0)

  // Matching
  paymentAttemptId String?
  matchStatus      String    @default("unmatched")
  // unmatched | matched | late | ignored | manual_review
  matchedAt        DateTime?
  matchReason      String?   @db.Text

  processedAt DateTime @default(now())

  paymentAttempt PaymentAttempt? @relation(fields: [paymentAttemptId], references: [id])

  @@unique([network, txHash, logIndex])
  @@index([toAddress, network])
  @@index([paymentAttemptId])
  @@index([matchStatus])
  @@index([blockNumber])
}

// ══════════════════════════════════════
// STATUS LOGS (audit trail)
// ══════════════════════════════════════

model PaymentStatusLog {
  id               String   @id @default(cuid())
  paymentAttemptId String
  oldStatus        String
  newStatus        String
  reason           String?  @db.Text
  metadata         String?  @db.Text // JSON
  actor            String? // system | admin:{userId}
  createdAt        DateTime @default(now())

  paymentAttempt PaymentAttempt @relation(fields: [paymentAttemptId], references: [id])

  @@index([paymentAttemptId])
  @@index([createdAt])
}

model OrderStatusLog {
  id        String   @id @default(cuid())
  orderId   String
  oldStatus String
  newStatus String
  reason    String?  @db.Text
  actor     String?
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([createdAt])
}

// ══════════════════════════════════════
// WATCHER CHECKPOINTS
// ══════════════════════════════════════

model WatcherCheckpoint {
  id         String   @id @default(cuid())
  network    String   @unique // TRC20 | BEP20
  lastBlock  Int      @default(0)
  lastScanAt DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ══════════════════════════════════════
// RECONCILIATION JOBS
// ══════════════════════════════════════

model ReconciliationJob {
  id          String    @id @default(cuid())
  type        String // full_scan | missed_tx | expired_check
  network     String?
  status      String    @default("pending") // pending | running | completed | failed
  fromBlock   Int?
  toBlock     Int?
  result      String?   @db.Text // JSON
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([status])
  @@index([createdAt])
}

// ══════════════════════════════════════
// AUDIT LOGS
// ══════════════════════════════════════

model AuditLog {
  id         String   @id @default(cuid())
  action     String // payment.created | payment.matched | payment.confirmed | order.approved | admin.manual_approve
  entityType String // payment_attempt | order | transfer_event
  entityId   String
  actor      String // system | admin:{id}
  details    String?  @db.Text // JSON
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
}
