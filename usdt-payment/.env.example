# ═══════════════════════════════════════
# USDT Payment System — Environment Config
# ═══════════════════════════════════════
# Copy to .env and fill in values

# Server
PORT=4000
NODE_ENV=development

# Database (PostgreSQL)
# Dùng cùng DATABASE_URL với project chính hoặc tạo DB riêng
DATABASE_URL=postgresql://postgres:password@localhost:5432/usdt_payment

# ─── TRON (TRC20) ───
TRON_PUBLIC_ADDRESS=TTmNqZhW4PkDXpPaTiSXzLnoWMdWf5xSp8
TRON_FULL_HOST=https://api.trongrid.io
TRONGRID_API_KEY=
TRC20_USDT_CONTRACT=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t
TRON_QR_IMAGE_URL=/images/tronusdt.jpg
TRON_REQUIRED_CONFIRMATIONS=20

# ─── BSC (BEP20) ───
BSC_PUBLIC_ADDRESS=0x66846F8135B3a521e924D1960d90F4C4aF844817
BSC_RPC_URL=https://bsc-dataseed.binance.org/
BEP20_USDT_CONTRACT=0x55d398326f99059fF775485246999027B3197955
BSC_QR_IMAGE_URL=/images/bscusdt.jpg
BSC_REQUIRED_CONFIRMATIONS=15

# ─── Payment Config ───
PAYMENT_EXPIRE_MINUTES=15
PAYMENT_STATUS_POLL_SECONDS=5
USDT_VND_RATE=25000

# ─── Worker Config ───
WORKER_POLL_INTERVAL_MS=10000

# ─── Matching ───
# Strict tolerance: 0.0005 USDT
AMOUNT_TOLERANCE=0.0005

# ─── Logging ───
LOG_LEVEL=info

# ═══════════════════════════════════════
# ⚠️ NO PRIVATE KEYS IN THIS FILE
# This system is WATCH-ONLY.
# Private keys are NOT needed for MVP.
# ═══════════════════════════════════════
